# MoveHome.org reads from its own Supabase project (vfnpmtqxrffppqajxxpb,
# MoveHome.org reads from its own Supabase project (vfnpmtqxrffppqajxxpb,
# eu-west-2). The anon key is the only credential the app needs for public
# reads — RLS gates everything. Service-role key is only used by API routes
# that forward enquiries.

# Vercel auto-injects these for Production/Preview/Development.
# For local dev: `vercel env pull .env.local`.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required server-side. Used by /api/enquire to insert into tbl_enquiries
# and forward the payload to the source agent. Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL — used in OAuth redirects and metadata.
NEXT_PUBLIC_SITE_URL=https://movehome.org
